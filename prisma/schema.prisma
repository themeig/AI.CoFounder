generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  startups      Startup[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Startup {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?  @db.Text
  website       String?
  sector        String
  phase         String
  country       String?
  teamSize      Int?
  mrr           Float    @default(0)
  users         Int      @default(0)
  burnRate      Float    @default(0)
  runway        Int      @default(0)
  fundingRaised Float    @default(0)
  equityPartner Boolean  @default(false)
  equityOffered Float?
  interactions  Interaction[]
  outcomes      Outcome[]
  agentConfigs  AgentConfig[]
  recommendations Recommendation[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([sector, phase])
}

model AgentConfig {
  id          String   @id @default(cuid())
  startupId   String
  startup     Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)
  type        String
  name        String
  isActive    Boolean  @default(true)
  settings    Json?
  messages    Message[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id          String     @id @default(cuid())
  agentId     String
  agent       AgentConfig @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role        String
  content     String     @db.Text
  metadata    Json?
  createdAt   DateTime   @default(now())
  @@index([agentId, createdAt])
}

model Interaction {
  id          String   @id @default(cuid())
  startupId   String
  startup     Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)
  agentType   String
  category    String
  advice      String   @db.Text
  context     Json
  helpful     Boolean?
  feedback    String?  @db.Text
  createdAt   DateTime @default(now())
  @@index([startupId, createdAt])
  @@index([agentType, category])
}

model Outcome {
  id          String   @id @default(cuid())
  startupId   String
  startup     Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)
  status      String
  metrics     Json
  keyFactors  String[]
  notes       String?  @db.Text
  recordedAt  DateTime @default(now())
  @@index([startupId, status])
}

model Pattern {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  sector      String?
  phase       String?
  conditions  Json
  successRate Float
  sampleSize  Int
  confidence  Float
  keyFactors  String[]
  failureModes String[]
  avgTimeToOutcome String?
  isActive    Boolean  @default(true)
  extractedBy String   @default("hermes_cron")
  playbooks   Playbook[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([sector, phase])
  @@index([confidence])
}

model Playbook {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  sector      String?
  phase       String?
  conditions  Json
  steps       Json
  patternId   String?
  pattern     Pattern? @relation(fields: [patternId], references: [id])
  successRate Float    @default(0)
  timesUsed   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Recommendation {
  id          String   @id @default(cuid())
  startupId   String
  startup     Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)
  patternId   String?
  pattern     Pattern? @relation(fields: [patternId], references: [id])
  type        String
  title       String
  content     String   @db.Text
  priority    Int      @default(1)
  isRead      Boolean  @default(false)
  isActedOn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  @@index([startupId, isRead])
}
